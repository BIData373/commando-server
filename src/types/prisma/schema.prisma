model Assignee {
  id    Int     @id @default(autoincrement())
  name  String
  color String
  icon  String?

  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // Meta Fields
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  users        AssigneeUser[]
  taskStatuses AssigneeTaskStatus[]
  messages     Message[]

  @@map("assignees")
}

model AssigneeTaskStatus {
  taskId     Int @map("task_id")
  assigneeId Int @map("assignee_id")
  statusId   Int @map("status_id")

  task     Task            @relation(fields: [taskId], references: [id])
  assignee Assignee        @relation(fields: [assigneeId], references: [id])
  status   WorkspaceStatus @relation(fields: [statusId], references: [id])

  @@id([taskId, assigneeId])
  @@map("assignee_task_statuses")
}

model AssigneeUser {
  assigneeId Int @map("assignee_id")
  userId     Int @map("user_id")

  assignee Assignee @relation(fields: [assigneeId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@id([assigneeId, userId])
  @@map("assignee_users")
}

model Message {
  id      Int    @id @default(autoincrement())
  content String @db.Text

  assigneeId Int @map("assignee_id")
  taskId     Int @map("task_id")

  assignee Assignee @relation(fields: [assigneeId], references: [id])
  task     Task     @relation(fields: [taskId], references: [id])

  // Meta Fields
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  @@map("messages")
}

model Permission {
  userId      Int            @map("user_id")
  workspaceId Int            @map("workspace_id")
  type        PermissionType

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@id([userId, workspaceId])
  @@map("permissions")
}

enum PermissionType {
  VIEWER
  MANAGER
}

model Pikud {
  id   Int     @id @default(autoincrement())
  name String
  icon String?

  // Meta Fields
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  workspaces Workspace[]

  @@map("pikuds")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../src/types/prisma/"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id   Int    @id @default(autoincrement())
  name String

  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  // Meta Fields
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  tasks Task[]

  tags Tag[] @relation("sources_tags")

  @@map("sources")
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String

  // Meta Fields (no deletedAt/deletedBy)
  createdAt DateTime @default(now()) @map("created_at")
  createdBy Int      @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy Int      @map("updated_by")

  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  tasks   Task[]   @relation("tasks_tags")
  sources Source[] @relation("sources_tags")

  @@map("tags")
}

model Task {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?  @db.Text
  flagged      Boolean  @default(false)
  deadlineType String   @map("deadline_type")
  issuedAt     DateTime @default(now()) @map("issued_at")
  dueDate      DateTime @map("due_date")
  notes        Json?

  // Meta Fields
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  sourceId Int    @map("source_id")
  source   Source @relation(fields: [sourceId], references: [id])

  tags             Tag[]                @relation("tasks_tags")
  assigneeStatuses AssigneeTaskStatus[]
  messages         Message[]
  history          TaskHistory[]

  @@map("tasks")
}

model TaskHistory {
  id        Int           @id @default(autoincrement())
  action    HistoryAction
  field     String
  value     String?
  timestamp DateTime      @default(now())

  taskId      Int @map("task_id")
  workspaceId Int @map("workspace_id")
  userId      Int @map("user_id")

  task      Task      @relation(fields: [taskId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("tasks_history")
}

enum HistoryAction {
  CREATE
  UPDATE
  DUPLICATE
  DELETE
}

model User {
  id   Int    @id @default(autoincrement())
  upn  String @unique
  info Json?

  assignees   AssigneeUser[]
  permissions Permission[]
  history     TaskHistory[]

  @@map("users")
}

model Workspace {
  id                     Int     @id @default(autoincrement())
  title                  String
  urlName                String  @map("url_name")
  icon                   String?
  assigneeStatusEditable Boolean @default(false) @map("assignee_status_editable")

  // Meta Fields
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy Int       @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy Int       @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  pikudId Int   @map("pikud_id")
  pikud   Pikud @relation(fields: [pikudId], references: [id])

  tags              Tag[]
  tasks             Task[]
  workspaceStatuses WorkspaceStatus[]
  permissions       Permission[]
  tasksHistory      TaskHistory[]
  sources           Source[]
  assignees         Assignee[]

  @@map("workspaces")
}

model WorkspaceStatus {
  id         Int    @id @default(autoincrement())
  name       String
  color      String
  statusType String @map("status_type")

  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  assigneeTaskStatuses AssigneeTaskStatus[]

  @@map("workspace_statuses")
}
