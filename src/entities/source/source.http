# @import ../../../global.http

### Create Source — valid payload
POST {{baseUrl}}/source
...headers

{
  "name": "Radio",
  "workspaceId": {{workspaceId}}
}

{{@response
  exports.sourceId = response.parsedBody.id;
}}

?? status == 201

### Create Source — missing required field (expect 400)
POST {{baseUrl}}/source
...headers

{
  "workspaceId": {{workspaceId}}
}

?? status == 400

### Get all Sources in workspace
GET {{baseUrl}}/source?workspaceId={{workspaceId}}
...headers

?? status == 200

### Get Source by id
GET {{baseUrl}}/source/{{sourceId}}
...headers

?? status == 200

### Update Source
PATCH {{baseUrl}}/source/{{sourceId}}
...headers

{
  "name": "Radio Updated"
}

?? status == 200

### Delete Source — non-existent id (expect 400)
DELETE {{baseUrl}}/source/99999
...headers

?? status == 400

### Delete Source
DELETE {{baseUrl}}/source/{{sourceId}}
...headers

?? status == 200
