POST {{baseUrl}}/pikud
Content-Type: application/json

{
  "name": "Pikud HaZafon",
  "icon": "north-icon",
  "createdBy": 1,
  "updatedBy": 1
}

{{@response
  exports.pikudId = response.parsedBody.id;
}}

?? status == 201

