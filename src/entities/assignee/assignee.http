# @import ../../../global.http

### Create Assignee — valid payload
POST {{baseUrl}}/assignee
...headers

{
  "name": "Alpha Team",
  "color": "#E53935",
  "icon": "shield",
  "workspaceId": {{workspaceId}}
}

{{@response
  exports.assigneeId = response.parsedBody.id;
}}

?? status == 201

### Create Assignee — missing required fields (expect 400)
POST {{baseUrl}}/assignee
...headers

{
  "color": "#E53935"
}

?? status == 400

### Get all Assignees in workspace
GET {{baseUrl}}/assignee?workspaceId={{workspaceId}}
...headers

?? status == 200

### Get Assignee by id
GET {{baseUrl}}/assignee/{{assigneeId}}
...headers

?? status == 200

### Update Assignee
PATCH {{baseUrl}}/assignee/{{assigneeId}}
...headers

{
  "name": "Alpha Team Updated",
  "icon": "shield-check"
}

?? status == 200

### Delete Assignee — non-existent id (expect 400)
DELETE {{baseUrl}}/assignee/99999
...headers

?? status == 400

### Delete Assignee
DELETE {{baseUrl}}/assignee/{{assigneeId}}
...headers

?? status == 200
