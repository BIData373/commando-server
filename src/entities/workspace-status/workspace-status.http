# @import ../../../global.http

### Create WorkspaceStatus — valid payload
POST {{baseUrl}}/workspace-status
Content-Type: application/json

{
  "name": "In Progress",
  "color": "#FFD700",
  "statusType": "active",
  "workspaceId": 1
}

{{@response
  exports.workspaceStatusId = response.parsedBody.id;
}}

?? status == 201

