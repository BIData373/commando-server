# @import ../../../global.http

### Create Tag — valid payload
POST {{baseUrl}}/tag
Content-Type: application/json

{
  "name": "Urgent",
  "workspaceId": 1,
  "createdBy": 1,
  "updatedBy": 1
}

{{@response
  exports.tagId = response.parsedBody.id;
}}

?? status == 201

### Create Tag — missing required field (expect 400)
POST {{baseUrl}}/tag
Content-Type: application/json

{
  "workspaceId": 1
}

?? status == 400

### Get all Tags
GET {{baseUrl}}/tag

?? status == 200

### Get Tag by id
GET {{baseUrl}}/tag/{{tagId}}

?? status == 200

### Update Tag
PATCH {{baseUrl}}/tag/{{tagId}}
Content-Type: application/json

{
  "name": "Critical",
  "updatedBy": 1
}

?? status == 200

### Delete Tag — non-existent id (expect 400 from @EntityExists)
DELETE {{baseUrl}}/tag/99999
Content-Type: application/json

{
  "id": 99999
}

?? status == 400

### Delete Tag
DELETE {{baseUrl}}/tag/{{tagId}}
Content-Type: application/json

{
  "id": {{tagId}}
}

?? status == 200
