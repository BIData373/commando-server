# @import ../../../global.http

### Create Tag — valid payload
POST {{baseUrl}}/tag
...headers

{
  "name": "Urgent",
  "workspaceId": 1
}

{{@response
  exports.tagId = response.parsedBody.id;
}}

?? status == 201

### Create Tag — missing required field (expect 400)
POST {{baseUrl}}/tag
...headers

{
  "name": "a",
  "workspaceId": 42
}

?? status == 400

### Get all Tags
GET {{baseUrl}}/tag?workspaceId={{workspaceId}}
...headers

?? status == 200

### Get Tag by id
GET {{baseUrl}}/tag/{{tagId}}
...headers

?? status == 200

### Update Tag
PATCH {{baseUrl}}/tag/{{tagId}}
...headers

{
  "name": "Critical"
}

?? status == 200

### Delete Tag — non-existent id (expect 400 from @EntityExists)
DELETE {{baseUrl}}/tag/9999
...headers

?? status == 400

### Delete Tag
DELETE {{baseUrl}}/tag/{{tagId}}
...headers

?? status == 200
